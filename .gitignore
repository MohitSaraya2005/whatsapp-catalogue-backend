# Dependency folders (Never upload these, they are downloaded fresh during deployment)
node_modules/
jspm_packages/
web_modules/

# Environment variables and secrets (CRITICAL: Keeps your database password and Meta keys safe)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Operating System files (System garbage generated by your computer)
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs and text editors settings
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?